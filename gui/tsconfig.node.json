  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [ "node" ],
    "lib": [ "ES2022" ],
    "resolveJsonModule": true
  },
  "include": [ "vite.config.ts", "server/**/*.ts" ]
}
